# このファイルを secrets.toml としてコピーし、実値を設定してください（Gitへ登録禁止）。
[app]
mode = "cloud" # cloud / demo
timezone = "Asia/Tokyo"
public_url = "https://your-app.example.com"
allowed_emails = ["teacher@example.com"]

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
anon_key = "YOUR_PUBLISHABLE_OR_ANON_KEY"

[google_calendar]
calendar_id = "primary"
